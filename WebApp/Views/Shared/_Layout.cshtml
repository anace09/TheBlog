@{

    var firstName = Context.Session.GetString("firstName");
    var lastName = Context.Session.GetString("lastName");
    var displayName = (!string.IsNullOrEmpty(firstName) || !string.IsNullOrEmpty(lastName))
        ? $"{firstName} {lastName}".Trim()
        : "Гость";

}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/shared/layout.css" />
</head>
<body>

    <!-- HEADER -->
    <header>
        <div class="header-inner">
            <a href="/" class="header-logo">@displayName</a>

            <nav class="header-nav">
                <a class="nav-link" asp-controller="Posts" asp-action="Index">Blog</a>
                <a class="nav-link" href="#">Projects</a>
                <a class="nav-link" href="#">About</a>
                <a class="nav-link" href="#">Newsletter</a>
                <a href="#" class="header-cta"></a>
            </nav>
        </div>
    </header>

    <!-- MAIN -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="footer-inner">
            <span class="footer-copy">© 2026</span>
            <a href="https://github.com" class="footer-link" target="_blank">Github</a>
            <a href="https://linkedin.com" class="footer-link" target="_blank">LinkedIn</a>
            <a href="mailto:you@email.com" class="footer-link">Email</a>
        </div>
    </footer>

</body>
</html>
