{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "posts-route": {
        "ClusterId": "posts-cluster",
        "Match": {
          "Path": "/api/posts/{**catch-all}"
        }
      },
      "categories-route": {
        "ClusterId": "posts-cluster",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "tags-route": {
        "ClusterId": "posts-cluster",
        "Match": {
          "Path": "/api/tags/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": { "Address": "https://localhost:8101" }
        }
      },
      "posts-cluster": {
        "Destinations": {
          "posts-service": { "Address": "https://localhost:8091" }
        }
      }
    }
  }
}