{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "web-api-route": { // web-api-route - Название для одного из путей.
        "ClusterId": "web-api", // web-api Id кластера из кластеров.
        "Match": {
          "Path": "/api/{**catch-all}" // /api/{**catch-all} - Пути для кластера web-apis
        }
      }
    },
    "Clusters": {
      "web-api": { // web-api - Название кластера для api-server.
        "Destinations": {
          "api-server": { "Address": "http://localhost:8090" } // api-server - Название точки назначения + адресс сервиса.
        }
      }
    }
  }
}
